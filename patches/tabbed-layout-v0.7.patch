From: v8065791 <v8065791@users.noreply.github.com>
Date: Fri, 1 May 2026 00:00:00 -0300
Subject: [PATCH] Add tabbed layout

This patch adds a Sway-style tabbed layout to dwl.

Sway's tabbed arrangement gives each child the full parent rectangle; the
selected child is what the user sees. dwl does not have Sway's container
titlebar tree, so this layout implements the core geometry behavior: every
visible tiled client is resized to the monitor work area and the focused
client is raised to the top of the tile layer. Existing focusstack bindings
then behave like tab switching.

Apply with:

    git apply patches/tabbed-layout-v0.7.patch

Then rebuild config.h if needed:

    cp config.def.h config.h
    make

---
 config.def.h |  2 ++
 dwl.c        | 35 +++++++++++++++++++++++++++++++++++
 2 files changed, 37 insertions(+)

diff --git a/config.def.h b/config.def.h
index 8a6eda0..1111111 100644
--- a/config.def.h
+++ b/config.def.h
@@ -40,9 +40,10 @@ static const Rule rules[] = {
 static const Layout layouts[] = {
 	/* symbol     arrange function */
 	{ "[]=",      tile },
 	{ "><>",      NULL },    /* no layout function means floating behavior */
 	{ "[M]",      monocle },
+	{ "[T]",      tabbed },
 };
 
 /* monitors */
@@ -134,9 +135,10 @@ static const Key keys[] = {
 	{ MODKEY|WLR_MODIFIER_SHIFT, XKB_KEY_c,           killclient,       {0} },
 	{ MODKEY,                    XKB_KEY_t,           setlayout,        {.v = &layouts[0]} },
 	{ MODKEY,                    XKB_KEY_f,           setlayout,        {.v = &layouts[1]} },
 	{ MODKEY,                    XKB_KEY_m,           setlayout,        {.v = &layouts[2]} },
+	{ MODKEY,                    XKB_KEY_w,           setlayout,        {.v = &layouts[3]} },
 	{ MODKEY,                    XKB_KEY_space,       setlayout,        {0} },
 	{ MODKEY|WLR_MODIFIER_SHIFT, XKB_KEY_space,       togglefloating,   {0} },
 	{ MODKEY,                    XKB_KEY_e,           togglefullscreen, {0} },
 	{ MODKEY,                    XKB_KEY_0,           view,             {.ui = ~0} },
diff --git a/dwl.c b/dwl.c
index 2222222..3333333 100644
--- a/dwl.c
+++ b/dwl.c
@@ -305,9 +305,10 @@ static void spawn(const Arg *arg);
 static void startdrag(struct wl_listener *listener, void *data);
 static void tag(const Arg *arg);
 static void tagmon(const Arg *arg);
+static void tabbed(Monitor *m);
 static void tile(Monitor *m);
 static void togglefloating(const Arg *arg);
 static void togglefullscreen(const Arg *arg);
 static void toggletag(const Arg *arg);
@@ -2377,9 +2378,43 @@ tagmon(const Arg *arg)
 	if (!sel)
 		return;
 	setmon(sel, dirtomon(arg->i), 0);
 }
+
+void
+tabbed(Monitor *m)
+{
+	Client *c, *sel = focustop(m);
+	struct wlr_box geo = m->w;
+	unsigned int n = 0;
+
+	wl_list_for_each(c, &clients, link) {
+		if (VISIBLEON(c, m) && !c->isfloating && !c->isfullscreen)
+			n++;
+	}
+
+	if (n == 0)
+		return;
+
+	/*
+	 * Like Sway's tabbed layout, every child gets the full parent box.
+	 * dwl has no container titlebar tree here, so there is no titlebar offset;
+	 * focusstack() changes the selected tab, and the selected client is raised.
+	 */
+	wl_list_for_each(c, &clients, link) {
+		if (!VISIBLEON(c, m) || c->isfloating || c->isfullscreen)
+			continue;
+
+		resize(c, geo, 0);
+		wlr_scene_node_reparent(&c->scene->node, layers[LyrTile]);
+	}
+
+	if (sel && VISIBLEON(sel, m) && !sel->isfloating && !sel->isfullscreen) {
+		wlr_scene_node_raise_to_top(&sel->scene->node);
+		resize(sel, geo, 0);
+	}
+}
 
 void
 tile(Monitor *m)
 {
 	unsigned int mw, my, ty;
